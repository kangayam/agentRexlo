{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "../audit-dist",
    "module": "commonjs",
    "moduleResolution": "node",
    "isolatedModules": false,
    "incremental": false,
    "skipLibCheck": true,
    "rootDir": "..",
    "paths": { "@/*": ["../*"] }
  },
  "include": [
    "../lib/**/*.ts",
    "./audit-recon.ts"
  ],
  "exclude": ["../node_modules"]
}
